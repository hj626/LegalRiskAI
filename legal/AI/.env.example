# ================================================
# AI 서비스 환경 변수 설정 예시
# ================================================
# 이 파일을 .env로 복사한 후 실제 값으로 수정하세요
# cp .env.example .env

# ========================
# Gemini API 키 (필수)
# ========================
# Google AI Studio에서 발급: https://aistudio.google.com/
GEMINI_API_KEY=your-api-key-here

# ========================
# CORS 허용 도메인
# ========================
ALLOWED_ORIGINS=http://localhost:8484,http://localhost:3000,http://localhost:5173

# ========================
# 데이터 경로 (Docker 사용 시 자동 설정됨)
# 로컬 직접 실행 시에만 수정 필요
# ========================
# PARQUET_PATH=/app/data/korean_precedents_embedded.parquet
# CSV_PATH=/app/data/korean_precedents_clean.csv
# FAISS_INDEX_PATH=/app/data/case_index.faiss
# MODEL_PATH=/app/models/saved_mode3
